<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ureca.reservation.model.dao.ReservationDao">

    <!--
        Reservation DTO н”„лЎңнҚјнӢ°лӘ…мқҙ DB м»¬лҹјлӘ…кіј лҸҷмқј(snake_case)н•ҳм—¬
        лі„лҸ„ мқҙлҰ„ ліҖнҷҳ м—Ҷмқҙ resultMap м„ м–ё
    -->
    <resultMap id="reservationMap" type="com.ureca.dto.Reservation">
        <id     column="reservation_id" property="reservation_id"/>
        <result column="seat_id"        property="seat_id"/>
        <result column="user_id"        property="user_id"/>
        <result column="movie_id"       property="movie_id"/>
        <result column="hall_id"        property="hall_id"/>
        <result column="start_datetime" property="start_datetime"/>
    </resultMap>

    <!-- ======================== INSERT ======================== -->

    <insert id="add" parameterType="com.ureca.dto.Reservation">
        INSERT INTO reservation(reservation_id, seat_id, user_id, movie_id, hall_id, start_datetime)
        VALUES(#{reservation_id}, #{seat_id}, #{user_id}, #{movie_id}, #{hall_id}, #{start_datetime})
    </insert>

    <!-- ======================== UPDATE ======================== -->

    <update id="update" parameterType="com.ureca.dto.Reservation">
        UPDATE reservation
        SET seat_id        = #{seat_id},
            user_id        = #{user_id},
            movie_id       = #{movie_id},
            hall_id        = #{hall_id},
            start_datetime = #{start_datetime}
        WHERE reservation_id = #{reservation_id}
    </update>

    <!-- ======================== DELETE ======================== -->

    <delete id="remove" parameterType="int">
        DELETE FROM reservation
        WHERE  reservation_id = #{reservationId}
    </delete>

    <!-- ======================== SELECT ======================== -->

    <select id="search" parameterType="int" resultMap="reservationMap">
        SELECT reservation_id, seat_id, user_id, movie_id, hall_id, start_datetime
        FROM   reservation
        WHERE  reservation_id = #{reservationId}
    </select>

    <select id="searchAll" resultMap="reservationMap">
        SELECT reservation_id, seat_id, user_id, movie_id, hall_id, start_datetime
        FROM   reservation
        ORDER  BY reservation_id
    </select>

    <select id="searchByMovie" parameterType="int" resultMap="reservationMap">
        SELECT reservation_id, seat_id, user_id, movie_id, hall_id, start_datetime
        FROM   reservation
        WHERE  movie_id = #{movieId}
    </select>

    <select id="searchByUserId" parameterType="int" resultMap="reservationMap">
        SELECT reservation_id, seat_id, user_id, movie_id, hall_id, start_datetime
        FROM   reservation
        WHERE  user_id = #{userId}
        ORDER  BY reservation_id
    </select>

    <!--
        isSeatTaken(int movieId, int seatId)
        лӢӨмӨ‘ нҢҢлқјлҜён„°: param1 = movieId, param2 = seatId
        SELECT COUNT(*) вҶ’ boolean мһҗлҸҷ ліҖнҷҳ (0 = false, 1мқҙмғҒ = true)
    -->
    <select id="isSeatTaken" resultType="boolean">
        SELECT COUNT(*)
        FROM   reservation
        WHERE  movie_id = #{param1}
          AND  seat_id  = #{param2}
        LIMIT  1
    </select>

    <!--
        isSeatTaken(int movieId, int hallId, Timestamp startDatetime, int seatId) мҳӨлІ„лЎңл”© лІ„м „
        XML IDлҠ” мң мқјн•ҙм•ј н•ҳлҜҖлЎң isSeatTakenByScheduleлЎң л¶„лҰ¬
        DAO кө¬нҳ„мІҙм—җм„ң 4-нҢҢлқјлҜён„° isSeatTaken() нҳём¶ң мӢң мқҙ IDлҘј мӮ¬мҡ©
        лӢӨмӨ‘ нҢҢлқјлҜён„°: param1 = movieId, param2 = hallId,
                       param3 = startDatetime, param4 = seatId
    -->
    <select id="isSeatTakenBySchedule" resultType="boolean">
        SELECT COUNT(*)
        FROM   reservation
        WHERE  movie_id       = #{param1}
          AND  hall_id        = #{param2}
          AND  start_datetime = #{param3}
          AND  seat_id        = #{param4}
        LIMIT  1
    </select>

    <!-- ======================== мң нӢё ======================== -->

    <select id="nextReservationId" resultType="int">
        SELECT COALESCE(MAX(reservation_id), 0) + 1
        FROM   reservation
    </select>

</mapper>
